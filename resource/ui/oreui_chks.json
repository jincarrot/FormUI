{
    "namespace": "fui_ore_chks",
    "switch_toggle@common_toggles.switch_toggle": {
        "$checked_control": "fui_ore_chks.switch_toggle_checked_default",
        "$checked_hover_control": "fui_ore_chks.switch_toggle_checked_hover",
