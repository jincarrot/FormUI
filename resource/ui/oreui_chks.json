    "switch_toggle_checked_default": {
        "type": "panel",
        "controls": [
            {
                "border@fui_ore_base.border": {
                    "layer": 0
                }
            },
            {
                "background@fui_ore_base.base": {
                    "$bg_color": [
                        0.24,
                        0.52,
                        0.15
                    ],
                    "$shadow_alpha_b_r": 0.1,
                    "$shadow_alpha_t_l": 0.2,
                    "layer": 1
                }
            },
            {
                "box_border@fui_ore_base.border": {
                    "anchor_from": "bottom_right",
                    "anchor_to": "bottom_right",
                    "layer": 4,
                    "size": [
                        "50%+2px",
                        "100%+4px"
                    ]
                }
            },
            {
                "box@fui_ore_base.base": {
                    "anchor_from": "bottom_right",
                    "anchor_to": "bottom_right",
                    "layer": 5,
                    "offset": [
                        0,
                        -4
                    ],
                    "size": [
                        "50%+2px",
                        "100%"
                    ]
                }
            },
            {
                "box_shadow@fui.w": {
                    "anchor_from": "bottom_right",
                    "anchor_to": "bottom_right",
                    "color": [
                        0.35,
                        0.35,
                        0.35
                    ],
                    "layer": 6,
                    "offset": [
                        -2,
                        -2
                    ],
                    "size": [
                        "50%-2px",
                        4
                    ]
                }
            },
            {
                "on@fui.w": {
                    "color": [
                        1,
                        1,
                        1
                    ],
                    "layer": 6,
                    "offset": [
                        "-25%+2px",
                        0
                    ],
                    "size": [
                        "2px",
                        "6px"
                    ]
                }
            }
        ]
    },
